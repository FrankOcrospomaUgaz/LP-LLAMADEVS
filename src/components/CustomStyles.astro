---
import '@fontsource-variable/dm-sans';
import '@fontsource-variable/space-grotesk';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'DM Sans Variable';
    --aw-font-serif: 'DM Sans Variable';
    --aw-font-heading: 'Space Grotesk Variable';

    --aw-color-primary: 8 145 178;
    --aw-color-secondary: 234 88 12;
    --aw-color-accent: 163 230 53;

    --aw-color-text-heading: 13 18 27;
    --aw-color-text-default: 23 29 37;
    --aw-color-text-muted: 23 29 37;
    --aw-color-text-muted-alpha: 0.68;
    --aw-color-text-page: var(--aw-color-text-default);
    --aw-color-bg-page: 245 243 238;

    --aw-color-bg-page-dark: 7 10 18;

    ::selection {
      background-color: rgba(8, 145, 178, 0.25);
      color: #f8fafc;
    }
  }

  .dark {
    --aw-font-sans: 'DM Sans Variable';
    --aw-font-serif: 'DM Sans Variable';
    --aw-font-heading: 'Space Grotesk Variable';

    --aw-color-primary: 34 211 238;
    --aw-color-secondary: 251 146 60;
    --aw-color-accent: 190 242 100;

    --aw-color-text-heading: 239 246 255;
    --aw-color-text-default: 226 231 245;
    --aw-color-text-muted: 226 231 245;
    --aw-color-text-muted-alpha: 0.7;
    --aw-color-text-page: var(--aw-color-text-default);
    --aw-color-bg-page: 7 10 18;

    ::selection {
      background-color: rgba(34, 211, 238, 0.28);
      color: #f8fafc;
    }
  }
</style>

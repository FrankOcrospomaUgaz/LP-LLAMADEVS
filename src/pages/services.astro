---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Servicios - llamadevs',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Servicios"
    title="Producto y tecnologia para operar sin friccion"
    subtitle="Squads senior para hospitality y retail: discovery, integraciones criticas y soporte 24/7."
    actions={[
      { variant: 'primary', text: 'Agenda demo', href: '/contact' },
      { variant: 'secondary', text: 'Ver casos', href: '/#casos' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1800&q=80',
      alt: 'Dashboard operativo',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Servicios core"
    subtitle="Equipos completos para llevar tu vertical a produccion con calidad y velocidad."
    columns={3}
    items={[
      {
        title: 'Squad completo',
        description: 'PM, UX, FE, BE y QA listos para operar.',
        icon: 'tabler:users-group',
      },
      {
        title: 'Discovery y UX',
        description: 'Flujos claros, prototipos y validacion rapida.',
        icon: 'tabler:layout-dashboard',
      },
      {
        title: 'Integraciones criticas',
        description: 'Pagos, ERP, contabilidad, BI y legacy.',
        icon: 'tabler:plug-connected',
      },
      {
        title: 'QA automatizado',
        description: 'Suites de pruebas para evitar regresiones.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'SRE y observabilidad',
        description: 'Alertas, trazas y dashboards en tiempo real.',
        icon: 'tabler:activity',
      },
      {
        title: 'Data y BI',
        description: 'Modelos de datos listos para analitica.',
        icon: 'tabler:chart-bar',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    items={[
      {
        title: 'Discovery y roadmap',
        description: 'Definimos alcance, riesgos y entregables por fase.',
        icon: 'tabler:map',
      },
      {
        title: 'Delivery continuo',
        description: 'Sprints quincenales con demos y feedback real.',
        icon: 'tabler:repeat',
      },
      {
        title: 'QA automatizado',
        description: 'Quality gates para releases estables.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Control de costos',
        description: 'Infra optimizada y monitoreo de performance.',
        icon: 'tabler:currency-dollar',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1556740749-887f6717d7e4?auto=format&fit=crop&w=900&q=80',
      alt: 'Pagos y operaciones',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Como trabajamos</h3>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Menos caidas',
        description: 'SLA y alertas para evitar interrupciones.',
        icon: 'tabler:alarm',
      },
      {
        title: 'Operaciones mas rapidas',
        description: 'Flujos optimizados para front y back office.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Escala multi-sede',
        description: 'Arquitectura lista para crecer sin friccion.',
        icon: 'tabler:building-community',
      },
      {
        title: 'Analitica en tiempo real',
        description: 'KPIs y alertas por sede y canal.',
        icon: 'tabler:chart-line',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1522075469751-3a6694fb2f61?auto=format&fit=crop&w=900&q=80',
      alt: 'Equipo de producto',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Resultados en operacion</h3>
    </Fragment>
  </Content>

  <!-- Testimonials Widget *********** -->

  <Testimonials
    title="Equipos que ya operan con nosotros"
    testimonials={[
      {
        testimonial: `Reducimos tiempos de cierre y mejoramos el control de costos desde el primer mes.`,
        name: 'Carlos Vega',
        job: 'COO, Orion Hotels',
        image: {
          src: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=800&q=80',
          alt: 'Carlos Vega',
        },
      },
      {
        testimonial: `El POS y los reportes por sede nos dieron visibilidad real de la operacion.`,
        name: 'Lucia Ramos',
        job: 'Head of Ops, Alma Retail',
        image: {
          src: 'https://images.unsplash.com/photo-1544723795-3fb6469f5b39?auto=format&fit=crop&w=800&q=80',
          alt: 'Lucia Ramos',
        },
      },
      {
        testimonial: `La integracion con pagos y ERP fue rapida y sin friccion para nuestro equipo.`,
        name: 'Diego Paredes',
        job: 'CTO, Grupo Cumbre',
        image: {
          src: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=800&q=80',
          alt: 'Diego Paredes',
        },
      },
    ]}
    callToAction={{
      text: 'Agendar demo',
      href: '/contact',
      icon: 'tabler:chevron-right',
    }}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Agenda demo',
        href: '/contact',
      },
      {
        variant: 'secondary',
        text: 'Ver stack',
        href: '/#stack',
      },
    ]}
    title="Listos para lanzar tu vertical"
    subtitle="Cuadramos discovery y roadmap en 7 dias."
  />
</Layout>

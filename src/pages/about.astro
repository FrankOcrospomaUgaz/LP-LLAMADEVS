---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Sobre llamadevs',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Sobre llamadevs"
    image={{
      src: 'https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=2000&q=80',
      alt: 'Operacion hospitality',
    }}
  >
    <Fragment slot="title">
      Producto y tecnologia para operaciones <br />
      <span class="text-accent dark:text-white">que facturan todos los dias</span>
    </Fragment>

    <Fragment slot="subtitle">
      Somos un estudio de producto y tecnologia enfocado en hospitality y retail. Construimos SaaS con integraciones
      criticas, UX clara y soporte 24/7 para equipos que operan en vivo.
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->

  <Stats
    title="Metricas de operacion"
    stats={[
      { title: 'Go-live promedio', amount: '6-10 semanas' },
      { title: 'Integraciones activas', amount: '30+' },
      { title: 'Cobertura', amount: '24/7' },
      { title: 'Verticales', amount: '3' },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="Verticales que dominamos"
    subtitle="Procesos reales: POS, kioscos, PMS, delivery y analitica operativa."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Restaurante OS',
        description: 'Ordenes omnicanal, KDS, costos y mermas con visibilidad por sede.',
        icon: 'tabler:building-store',
      },
      {
        title: 'Hotel & Villas',
        description: 'PMS, channel manager y upsell de servicios con check-in sin friccion.',
        icon: 'tabler:hotel-service',
      },
      {
        title: 'Retail / POS',
        description: 'Inventario en tiempo real, POS offline-first e integracion e-commerce.',
        icon: 'tabler:device-desktop',
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    columns={3}
    isAfterContent={true}
    items={[
      {
        title: 'Discovery y UX',
        description: 'Flujos claros, prototipos y validacion rapida con stakeholders.',
        icon: 'tabler:layout-dashboard',
      },
      {
        title: 'Integraciones criticas',
        description: 'Pagos, ERP, contabilidad, BI y sistemas legados.',
        icon: 'tabler:plug-connected',
      },
      {
        title: 'SRE y observabilidad',
        description: 'Alertas, trazas y dashboards para operar con SLA.',
        icon: 'tabler:activity',
      },
      {
        title: 'QA automatizado',
        description: 'Suites de pruebas que previenen regresiones en produccion.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Data y BI',
        description: 'Modelos de datos listos para analitica y reportes por sede.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Seguridad y compliance',
        description: 'Control de accesos, hardening y auditorias regulares.',
        icon: 'tabler:shield-lock',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&w=1740&q=80',
      alt: 'Equipo de producto',
    }}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="Nuestros valores"
    subtitle="Operacion real con disciplina de producto y tecnologia."
    items={[
      {
        title: 'Entrega continua',
        description: 'Sprints con objetivos claros y releases sin friccion.',
      },
      {
        title: 'Ownership y transparencia',
        description: 'Visibilidad de roadmap, riesgos y avances en todo momento.',
      },
      {
        title: 'Calidad operativa',
        description: 'Procesos, QA y soporte listos para operar 24/7.',
      },
    ]}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="Resultados reales"
    subtitle="Indicadores que importan en operaciones de alta demanda."
    isReversed={true}
    callToAction={{
      text: 'Ver casos',
      href: '/#casos',
    }}
    items={[
      {
        title: 'Time-to-value rapido',
        description: 'Onboarding y go-live en semanas, no meses.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Menos friccion operativa',
        description: 'Automatizacion de procesos y visibilidad por sede.',
        icon: 'tabler:stack-2',
      },
      {
        title: 'Escala multi-sede',
        description: 'Arquitectura lista para crecer sin reescrituras.',
        icon: 'tabler:scale',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Cobertura regional"
    tagline="Equipo remoto"
    columns={4}
    items={[
      {
        title: 'LATAM',
        description: 'Operaciones y soporte para equipos regionales.',
      },
      {
        title: 'USA',
        description: 'Proyectos y despliegues para cadenas multi-sede.',
      },
      {
        title: 'Europa',
        description: 'Integraciones y cumplimiento para operaciones globales.',
      },
      {
        title: 'Remoto',
        description: 'Squads distribuidos con horarios extendidos.',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Soporte directo"
    tagline="Contacto"
    columns={2}
    items={[
      {
        title: 'Chat con un especialista',
        description: 'Cuadramos discovery y una demo sobre tu vertical.',
        icon: 'tabler:messages',
      },
      {
        title: 'Linea directa',
        description: 'Soporte 24/7 para operaciones criticas.',
        icon: 'tabler:headset',
      },
    ]}
  />
</Layout>
